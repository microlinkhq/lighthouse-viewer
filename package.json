{
  "name": "lighthouse-viewer",
  "description": "Lighthouse Viewer as service",
  "homepage": "https://lighthouse-viewer.microlink.io",
  "version": "1.1.0",
  "main": "src/index.js",
  "author": {
    "email": "hello@microlink.io",
    "name": "microlink.io",
    "url": "https://microlink.io"
  },
  "contributors": [
    {
      "name": "Kiko Beats",
      "email": "josefrancisco.verdu@gmail.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microlinkhq/lighthouse-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/microlinkhq/lighthouse-viewer/issues"
  },
  "keywords": [
    "lighthouse",
    "microservice",
    "viewer"
  ],
  "dependencies": {
    "debug-logfmt": "~1.4.0",
    "dlv": "~1.1.3",
    "got": "~11.8.6",
    "lighthouse": "~13.4.0",
    "send-http": "~1.0.2",
    "to-query": "~1.6.12"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "ci-publish": "latest",
    "github-generate-release": "latest",
    "finepack": "latest",
    "git-authors-cli": "latest",
    "git-dirty": "latest",
    "husky": "latest",
    "lint-staged": "latest",


    "standard": "latest",
    "standard-markdown": "latest",
    "standard-version": "latest"
  },
  "engines": {
    "node": ">= 12"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "contributors": "(git-authors-cli && finepack && git add package.json && git commit -m 'build: contributors' --no-verify) || true",
    "dev": "TZ=UTC NODE_ENV=development DEBUG=lighthouse-viewer* watchexec -s SIGKILL -e 'js,css,html' -r 'node src/server.js'",
    "lint": "standard-markdown README.md && standard",
    "postrelease": "npm run release:tags && npm run release:github && (ci-publish || npm publish --access=public)",
    "prerelease": "npm run contributors",
    "pretest": "npm run lint",
    "release": "standard-version -a",
    "release:github": "github-generate-release",
    "release:tags": "git push --follow-tags origin HEAD:master",
    "start": "TZ=UTC NODE_ENV=production DEBUG=lighthouse-viewer* node index.js",
    "test": "exit 0"
  },
  "private": true,
  "license": "MIT",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0
      ]
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "package.json": [
      "finepack"
    ],
    "*.js": [
      "npx @kikobeats/prettier-standard",
      "standard --fix"
    ],
    "*.md": [
      "standard-markdown"
    ]
  }
}
